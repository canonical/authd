# Configuration file for provisioning the e2e-tests VM.
# It only contains VM-level settings; broker credentials go in
# e2e-tests/e2e-tests-<broker>.env (see the .env.template files there).
# Copy this template to config.env and customize the values for your environment.

# Path to the SSH public key that will be injected into the VM for root access.
SSH_PUBLIC_KEY_FILE="${HOME}/.ssh/id_rsa.pub"

# Base name for the libvirt domain; the release codename is appended (e.g. e2e-runner-noble).
VM_NAME_BASE=e2e-runner

# Ubuntu release codename to provision (e.g. noble, resolute).
RELEASE=resolute
