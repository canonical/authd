# Credentials for testing authd with the Microsoft Entra ID broker.
# Copy this file to e2e-tests-msentraid.env and fill in your values.
# That file is gitignored.
#
# run-tests.sh and yarf-console.sh load this file automatically when
# --broker authd-msentraid is specified.
# vm/provision-authd.sh also loads it when provisioning the VM for
# the Microsoft Entra ID broker.

BROKER=authd-msentraid

# Test user credentials
E2E_USER=
E2E_PASSWORD=
TOTP_SECRET=

# Microsoft Entra ID app credentials
AUTHD_MSENTRAID_ISSUER_ID=
AUTHD_MSENTRAID_CLIENT_ID=
AUTHD_MSENTRAID_CLIENT_SECRET=
