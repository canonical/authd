users:
    - name: success
      uid: 1111
      gid: 1111
      gecos: gecos for success
      dir: /home/success
      shell: /bin/sh/success
    - name: otheruser@example.com
      uid: 77777
      gid: 88888
      gecos: gecos for other user
      dir: /home/otheruser@example.com
      shell: /bin/sh/otheruser
      broker_id: broker-id
groups:
    - name: success
      gid: 1111
      ugid: success
    - name: group-success
      gid: 88888
      ugid: ugid-success
users_to_groups:
    - uid: 1111
      gid: 1111
    - uid: 1111
      gid: 88888
    - uid: 77777
      gid: 88888
schema_version: 2
